{
    "rewrites": [
      {
        "source": "/docs/(.*)",
        "destination": "/docs/$1"
      }
    ],
    "redirects": [
      {
        "source": "/documentation",
        "destination": "https://docs.elpulsar.app",
        "permanent": true
      }
    ],
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          }
        ]
      }
    ]
  }